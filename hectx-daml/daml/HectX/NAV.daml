module HectX.NAV where


template NAVSnapshot
  with
    navAdmin : Party
    nav : Decimal
    gav : Decimal
    reserves : Decimal
    liabilities : Decimal
    accruedFees : Decimal
    timestamp : Time
  where
    signatory navAdmin


template Supply
  with
    supplyAdmin : Party
    totalSupply : Decimal
  where
    signatory supplyAdmin
